{
  "name": "@chkp/ai-security-sdk",
  "version": "1.0.0",
  "description": "Check Point AI Security Official JS/TS SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/"],
  "scripts": {
    "build": "tsc",
    "prebuild": "yarn spec:fetch && yarn generate-api",
    "spec:fetch": "node scripts/fetch-api.js",
    "generate-api": "openapi-generator-cli generate && yarn post-generate",
    "post-generate": "node scripts/post-generate-api.js",
    "test": "TS_NODE_PROJECT=tsconfig.test.json mocha"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CheckPointSW/ai-security-js-ts-sdk"
  },
  "keywords": ["checkpoint", "ai", "security", "sdk", "workforce-ai", "ai-security"],
  "author": "Haim Kastner <haimk@checkpoint.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "debug": "^4.3.4",
    "guid-typescript": "^1.0.9",
    "node-fetch": "^2.6.6"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.16.3",
    "@types/debug": "^4.1.8",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.5.7",
    "@types/node-fetch": "^2.6.4",
    "dotenv": "^16.0.0",
    "mocha": "^11.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.3.4"
  },
  "resolutions": {
    "cross-spawn": "7.0.5"
  }
}
